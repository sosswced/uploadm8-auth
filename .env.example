# Copy to .env and fill in secrets. Never commit .env.
# See render.yaml for production-oriented defaults.

# Core
DATABASE_URL=postgresql://user:password@localhost:5432/uploadm8
JWT_SECRET=change-me-min-32-chars-random
BASE_URL=http://127.0.0.1:8000
# If OAuth providers redirect to a public URL (ngrok, cloudflared) but the app binds locally, set this to that
# public origin so /api/oauth/{platform}/callback matches the TikTok/Meta/Google portal registration.
# OAUTH_PUBLIC_BASE_URL=https://abc123.ngrok-free.app
FRONTEND_URL=http://127.0.0.1:8080
ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

# Tokens
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30
JWT_ISSUER=https://auth.uploadm8.com
JWT_AUDIENCE=uploadm8-app
TOKEN_ENC_KEYS=

# Redis / queues
REDIS_URL=
PROCESS_PRIORITY_QUEUE=uploadm8:process:priority
PROCESS_NORMAL_QUEUE=uploadm8:process:normal

# R2 / S3-compatible storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=uploadm8-media
R2_ENDPOINT_URL=
R2_PRESIGN_UPLOAD_TTL=7200

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://127.0.0.1:8080/billing/success.html?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://127.0.0.1:8080/index.html#pricing

# OpenAI / optional data files
OPENAI_API_KEY=
GAZETTEER_PLACES_PATH=
PADUS_PATH=
PADUS_LAYER=

# Observability
LOG_LEVEL=INFO
JSON_LOGS=1
SENTRY_DSN=
SENTRY_ENV=development
SENTRY_TRACES_RATE=0.1
METRICS_API_KEY=

# Hugging Face (write token for scripts that push datasets / create repos)
HF_TOKEN=
# Admin ML Hub sidebar links — set to repos you own (see scripts/init_hf_ml_hub_repos.py).
# Optional full-URL overrides if you use a non-default Hub endpoint:
# UM8_HF_DATASET_URL=
# UM8_TRACKIO_SPACE_URL=
UM8_HF_DATASET_REPO=
UM8_TRACKIO_SPACE_PATH=
# Server-side Trackio logging (match your Trackio project / HF Space)
TRACKIO_PROJECT=
TRACKIO_SPACE_ID=
# TRACKIO_RUN_ID=

# Rate limits / pool
RATE_LIMIT_ENABLED=true
DB_POOL_MIN=2
DB_POOL_MAX=10
TRUST_PROXY_HEADERS=0

# OAuth (set what you use)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=
# Meta App Review: use minimal scopes for reviewer login (pages_show_list, pages_read_engagement, business_management).
# full = production OAuth (instagram_*, publish_video, read_insights, …). custom = META_*_OAUTH_SCOPE overrides.
META_OAUTH_MODE=full
# META_INSTAGRAM_OAUTH_SCOPE=
# META_FACEBOOK_OAUTH_SCOPE=
# TikTok Login Kit: redirect URI must match the app config exactly — same scheme, host, port, path as
# BASE_URL + /api/oauth/tiktok/callback (no query string, no #fragment). Web docs often show https-only;
# for local dev use the exact URL you register (e.g. https ngrok tunnel) or a portal-approved test URL.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_WEBHOOK_SECRET=
