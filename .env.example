# UploadM8 — Environment template
# Copy to .env and fill with real values. NEVER commit .env to version control.
# Use Secret Manager or your host's env vars in production.

# Auth
JWT_SECRET=
JWT_ISSUER=https://auth.uploadm8.com
JWT_AUDIENCE=uploadm8-app
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis
REDIS_URL=redis://localhost:6379

# R2 / S3-compatible storage
# For direct browser uploads: add CORS policy to your R2 bucket (see r2-cors-policy.json).
# Cloudflare Dashboard: R2 → bucket → Settings → CORS Policy
# Or: npx wrangler r2 bucket cors set <BUCKET_NAME> --file r2-cors-policy.json
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=uploadm8-media
R2_ENDPOINT_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OAuth — Google / YouTube (restrict to YouTube Data API v3 in GCP Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# OAuth — Meta (Facebook / Instagram)
META_APP_ID=
META_APP_SECRET=

# Token encryption (comma-separated key versions)
TOKEN_ENC_KEYS=

# Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAIL_FROM=no-reply@yourdomain.com

# OpenAI (for AI captions/thumbnails)
OPENAI_API_KEY=

# Optional
FRONTEND_URL=https://app.uploadm8.com
ALLOWED_ORIGINS=https://app.uploadm8.com,https://uploadm8.com
LOG_LEVEL=INFO
